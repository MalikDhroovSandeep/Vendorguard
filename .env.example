# Database
DATABASE_URL=postgresql://user:password@localhost:5432/vendorguard

# NextAuth / Auth.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-strong-random-secret
# Optional aliases used by Auth.js
AUTH_URL=http://localhost:3000
AUTH_SECRET=replace-with-a-strong-random-secret

# OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP / email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=VendorGuard <noreply@vendorguard.com>
